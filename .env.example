# Backend
SECRET_KEY=changeme_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
TIMEZONE=Europe/Berlin

# Postgres
POSTGRES_USER=clok
POSTGRES_PASSWORD=changeme
POSTGRES_DB=clok
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Resend (Mailversand). Wenn RESEND_API_KEY leer ist, läuft das Backend
# im Dev-Modus und loggt Mails statt sie zu versenden – damit Domain-
# Verifizierung parallel möglich bleibt.
RESEND_API_KEY=
RESEND_FROM_EMAIL=clok@send.f-lv.de
RESEND_REPLY_TO=
APP_BASE_URL=https://clok.home.f-lv.de

# Onboarding
# Gültigkeit von Arbeitgeber-Einladungs-Tokens. Default 14 Tage –
# Resend rotiert auch innerhalb der Frist immer den Token.
EMPLOYER_INVITE_TTL_DAYS=14

# Public-Signup ist im Code vorbereitet, aber nicht aktiviert. Auf
# true setzen, wenn ein offener Registrierungs-Endpoint später ohne
# Refactor freigeschaltet werden soll.
PUBLIC_SIGNUP_ENABLED=false

# Frontend (Build-time)
VITE_API_BASE_URL=/api
