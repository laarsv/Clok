# Backend
SECRET_KEY=changeme_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
TIMEZONE=Europe/Berlin

# Postgres
POSTGRES_USER=clok
POSTGRES_PASSWORD=changeme
POSTGRES_DB=clok
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Brevo (Mailversand, Transactional-API). Wenn BREVO_API_KEY leer ist, läuft
# das Backend im Dev-Modus und loggt Mails statt sie zu versenden – damit die
# Domain-Verifizierung bei Brevo parallel möglich bleibt.
# EMAIL_FROM akzeptiert "clok@f-lv.de" oder "Clok <clok@f-lv.de>" (Absender
# muss in Brevo verifiziert sein). APP_BASE_URL steckt in den Mail-Links.
BREVO_API_KEY=
EMAIL_FROM=Clok <clok@mail.example.com>
EMAIL_REPLY_TO=
APP_BASE_URL=https://clok.example.com

# Google OAuth (Login via Google Workspace). Leer lassen ⇒ Google-Login aus.
# OAuth-Client in der Google Cloud Console anlegen (Typ: Web), autorisierte
# Redirect-URI: ${APP_BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Nur Accounts DIESER Workspace-Domain dürfen sich per Google anmelden.
GOOGLE_ALLOWED_DOMAIN=koenigswege.com
# Auto-Anlage neuer Google-Nutzer der Domain:
#   employer → als Arbeitgeber (kein Supervisor)   employee → als Mitarbeiter
#   (braucht GOOGLE_JIT_SUPERVISOR_EMAIL)           leer → aus (abweisen)
GOOGLE_JIT_ROLE=employer
# Nur für GOOGLE_JIT_ROLE=employee: Arbeitgeber, unter den neue MA gehängt werden.
GOOGLE_JIT_SUPERVISOR_EMAIL=

# Onboarding
# Gültigkeit von Arbeitgeber-Einladungs-Tokens. Default 14 Tage –
# Resend rotiert auch innerhalb der Frist immer den Token.
EMPLOYER_INVITE_TTL_DAYS=14

# Public-Signup ist im Code vorbereitet, aber nicht aktiviert. Auf
# true setzen, wenn ein offener Registrierungs-Endpoint später ohne
# Refactor freigeschaltet werden soll.
PUBLIC_SIGNUP_ENABLED=false

# Frontend (Build-time)
VITE_API_BASE_URL=/api
