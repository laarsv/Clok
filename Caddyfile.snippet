# In das zentrale Caddyfile auf dem Hetzner-Host einfügen. Caddy läuft im
# externen Docker-Netz "proxy" und spricht die Container über ihren Namen an.
# Caddy übernimmt TLS (automatisches HTTPS) und splittet /api/* aufs Backend,
# alles andere auf das nginx-gehostete SPA-Frontend.
# Einrückung mit Tabs (caddy-fmt-konform). Domain ggf. anpassen.

clok.vrwb.de {
	encode zstd gzip

	handle /api/* {
		reverse_proxy clok-api:8000
	}

	handle {
		reverse_proxy clok-web:80
	}
}
